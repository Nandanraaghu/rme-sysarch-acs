[Defines]
  INF_VERSION                    = 0x00010005
  BASE_NAME                      = RmeCxlTspRequesterLib
  FILE_GUID                      = 3B4DA0F2-1B05-4E5E-9829-6178C2EE2CB6
  MODULE_TYPE                    = BASE
  VERSION_STRING                 = 1.0
  LIBRARY_CLASS                  = CxlTspRequesterLib

[Sources]
  spdm-emu/library/cxl_tsp_requester_lib/cxl_tsp_send_receive.c
  spdm-emu/library/cxl_tsp_requester_lib/cxl_tsp_req_get_version.c
  spdm-emu/library/cxl_tsp_requester_lib/cxl_tsp_req_get_capabilities.c
  spdm-emu/library/cxl_tsp_requester_lib/cxl_tsp_req_set_configuration.c
  spdm-emu/library/cxl_tsp_requester_lib/cxl_tsp_req_get_configuration.c
  spdm-emu/library/cxl_tsp_requester_lib/cxl_tsp_req_get_configuration_report.c
  spdm-emu/library/cxl_tsp_requester_lib/cxl_tsp_req_lock_configuration.c
  spdm-emu/library/cxl_tsp_requester_lib/cxl_tsp_req_set_te_state.c

[Packages]
  MdePkg/MdePkg.dec
  ShellPkg/Application/rme-acs/uefi_app/RmeAcs.dec
  SecurityPkg/SecurityPkg.dec
  CryptoPkg/CryptoPkg.dec

[LibraryClasses]
  BaseLib
  BaseMemoryLib
  DebugLib
  SpdmRequesterLib
  SpdmTransportPciDoeLib
  PciDoeRequesterLib

[BuildOptions]
  GCC:*_*_*_CC_FLAGS         = -I$(WORKSPACE)/ShellPkg/Application/rme-acs/ext/include -I$(WORKSPACE)/ShellPkg/Application/rme-acs/ext/libspdm/include -I$(WORKSPACE)/ShellPkg/Application/rme-acs/ext/spdm-emu/include
  CLANGPDB:*_*_*_CC_FLAGS    = -I$(WORKSPACE)/ShellPkg/Application/rme-acs/ext/include -I$(WORKSPACE)/ShellPkg/Application/rme-acs/ext/libspdm/include -I$(WORKSPACE)/ShellPkg/Application/rme-acs/ext/spdm-emu/include
  CLANGDWARF:*_*_*_CC_FLAGS  = -I$(WORKSPACE)/ShellPkg/Application/rme-acs/ext/include -I$(WORKSPACE)/ShellPkg/Application/rme-acs/ext/libspdm/include -I$(WORKSPACE)/ShellPkg/Application/rme-acs/ext/spdm-emu/include
